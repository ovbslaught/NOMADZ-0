@tool
extends EditorPlugin

# NOMADZ-0 System Integration
const SYNC_SCRIPT_PATH = "res://scripts/sync_nomadz.sh" # Path to the bash script provided earlier

func _enter_tree():
	resource_saved.connect(_on_resource_saved)
	print("[NOMADZ-0] Sentinel Active: Persistence Layer Engaged.")

func _exit_tree():
	resource_saved.disconnect(_on_resource_saved)
	print("[NOMADZ-0] Sentinel Standby.")

func _on_resource_saved(resource: Resource):
	var path = resource.resource_path
	# Focus on Proton Blade and Core Logic evolution
	if "proton_blade" in path or "mother_brain" in path or path.ends_with(".gd"):
		_trigger_cosmic_sync(path)

func _trigger_cosmic_sync(file_changed: String):
	print("[NOMADZ-0] Delta detected in: ", file_changed)
	
	var output = []
	var exit_code = OS.execute("bash", [ProjectSettings.globalize_path(SYNC_SCRIPT_PATH)], output)
	
	if exit_code == 0:
		print("[NOMADZ-0] Sync Successful. Knowledge Base Updated.")
	else:
		printerr("[NOMADZ-0] Sync Failed. Check rclone/git credentials. Output: ", output)
