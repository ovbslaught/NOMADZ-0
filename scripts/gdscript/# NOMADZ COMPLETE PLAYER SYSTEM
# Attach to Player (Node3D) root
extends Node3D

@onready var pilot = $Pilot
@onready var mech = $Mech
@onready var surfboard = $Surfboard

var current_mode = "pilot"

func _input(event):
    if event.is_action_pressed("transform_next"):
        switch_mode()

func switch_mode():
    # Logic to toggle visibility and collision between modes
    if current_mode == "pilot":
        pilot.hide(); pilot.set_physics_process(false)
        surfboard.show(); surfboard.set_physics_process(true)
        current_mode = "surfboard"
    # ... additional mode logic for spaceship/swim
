# NOMADZ COMPLETE PLAYER SYSTEM
# Attach to Player (Node3D) root
extends Node3D

@onready var pilot = $Pilot
@onready var mech = $Mech
@onready var surfboard = $Surfboard

var current_mode = "pilot"

func _input(event):
    if event.is_action_pressed("transform_next"):
        switch_mode()

func switch_mode():
    # Logic to toggle visibility and collision between modes
    if current_mode == "pilot":
        pilot.hide(); pilot.set_physics_process(false)
        surfboard.show(); surfboard.set_physics_process(true)
        current_mode = "surfboard"
    # ... additional mode logic for spaceship/swim
