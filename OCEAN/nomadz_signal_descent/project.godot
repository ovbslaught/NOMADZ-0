; Engine configuration file - NOMADZ: SIGNAL DESCENT
; Godot 4.6 | Compatibility Renderer (GLES3)
; Sol / VultureCode / NOMADZ Universe

config_version=5

[application]

config/name="NOMADZ: Signal Descent"
config/description="A Metroidvania set in the NOMADZ universe. The Signalverse bleeds through. The COSMIC KEY is shattered. NORA must descend into Primal Station VULTURE-SIGMA to restore the MOTHER BRAIN link — or be consumed by the bleed."
config/version="0.1.0-alpha"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "2D")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://autoloads/GameManager.gd"
SignalverseManager="*res://autoloads/SignalverseManager.gd"
LoreDatabase="*res://autoloads/LoreDatabase.gd"
AudioManager="*res://autoloads/AudioManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/subwindow/embed_subwindows=true

